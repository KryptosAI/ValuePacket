# Chain selection: resolves contracts/deployments/<CHAIN>.json for addresses
CHAIN=base-sepolia

# Optional overrides
# RPC_URL=https://sepolia.base.org
# PAYMENT_CHANNEL_ADDRESS=0x...
# DEPLOYMENT_FILE=../../contracts/deployments/base-sepolia.json

# Block explorer API keys (free tier works without keys for low volume)
# ETHERSCAN_API_KEY=your-key-here
# BASESCAN_API_KEY=your-key-here

PORT=3001
