{
  "model": "amm_pool",
  "description": "Curve StableSwap — simplified stablecoin AMM. exchange adds to one reserve and subtracts from another (constant-sum-like vs constant-product). constant_product is expected to be violated for exchange functions since stable swaps trade near peg with low slippage.",
  "functions": [
    {
      "name": "exchange0to1",
      "guards": ["amt_gt_0", "dy_gt_0", "reserveY_ge_dy", "not_locked"],
      "effects": ["reentrancy_lock_acquire", "reserveX_add", "reserveY_sub", "reentrancy_lock_release"]
    },
    {
      "name": "exchange1to0",
      "guards": ["amt_gt_0", "dy_gt_0", "reserveX_ge_dx", "not_locked"],
      "effects": ["reentrancy_lock_acquire", "reserveX_sub", "reserveY_add", "reentrancy_lock_release"]
    },
    {
      "name": "addLiquidity",
      "guards": ["amt_gt_0", "dy_gt_0", "not_locked"],
      "effects": ["reserveX_add", "reserveY_add", "lp_mint_amt"]
    },
    {
      "name": "removeLiquidity",
      "guards": ["amt_gt_0", "lp_ge_amt", "reserveX_ge_dx", "reserveY_ge_dy", "not_locked"],
      "effects": ["lp_burn_amt", "reserveX_sub", "reserveY_sub"]
    }
  ],
  "invariants": ["nonneg_reserves", "nonneg_lp", "lp_integrity", "reentrancy_safe", "constant_product", "backing_amm"]
}
