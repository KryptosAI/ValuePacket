{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "git-submodules": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "minor and patch",
      "groupSlug": "minor-patch"
    }
  ],
  "schedule": ["before 4am on Monday"],
  "labels": ["deps"]
}
