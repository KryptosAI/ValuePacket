{
  "name": "@valuepacket/cli",
  "version": "0.1.0",
  "description": "ValuePacket CLI — the payment protocol for autonomous agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "valuepacket": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./demo": {
      "import": {
        "types": "./dist/demo.d.ts",
        "default": "./dist/demo.js"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "agent",
    "settlement",
    "payment",
    "channel",
    "blockchain",
    "ethereum",
    "web3",
    "ai",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@valuepacket/sdk": "*",
    "commander": "^13.0.0",
    "viem": "^2.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
