{
  "name": "@valuepacket/adapter-game",
  "version": "0.2.2",
  "description": "G.A.M.E framework adapter for ValuePacket — add payment channels to your G.A.M.E agents",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@valuepacket/sdk": "^0.2.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KryptosAI/ValuePacket.git",
    "directory": "adapters/game"
  },
  "homepage": "https://github.com/KryptosAI/ValuePacket#readme",
  "bugs": {
    "url": "https://github.com/KryptosAI/ValuePacket/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
