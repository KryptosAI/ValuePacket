# ─── ValuePacket CLI ──────────────────────────────────────
# Configuration for the ValuePacket payment protocol CLI.
#
# RPC endpoint
RPC_URL=http://localhost:8545

# Contract addresses (auto-detected from deployments/local.json for local)
SERVICE_REGISTRY_ADDRESS=
PAYMENT_CHANNEL_ADDRESS=
SPENDING_POLICY_ADDRESS=

# Token address (USDC on Base Sepolia OR MockUSDC on local)
USDC_TOKEN_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Agent private key (optional — demo generates ephemeral wallets)
AGENT_PRIVATE_KEY=
